{
  "name": "@freeside-auth/protocol",
  "version": "0.1.0",
  "private": true,
  "description": "Sealed wire-format schemas for identity overlay — User entity, Wallet entity, IdentityComponent, JWT claims, multi-credential proofs (SIWE / passkey / Dynamic / SeedVault). Consumers depend on these contracts; impls (loa-freeside/gateway issuer, midi onboarding writer, ruggy + future bot resolvers) satisfy them.",
  "license": "MIT",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./jwt-claims": "./src/jwt-claims.ts",
    "./jwt-claims.schema.json": "./src/jwt-claims.schema.json",
    "./user": "./src/user.ts",
    "./user.schema.json": "./src/user.schema.json",
    "./wallet": "./src/wallet.ts",
    "./wallet.schema.json": "./src/wallet.schema.json",
    "./identity-component": "./src/identity-component.ts",
    "./identity-component.schema.json": "./src/identity-component.schema.json",
    "./credential-dynamic": "./src/credential-dynamic.ts",
    "./credential-dynamic.schema.json": "./src/credential-dynamic.schema.json",
    "./resolve-result": "./src/resolve-result.ts",
    "./resolve-result.schema.json": "./src/resolve-result.schema.json",
    "./types": "./src/types.ts",
    "./api": "./src/api/index.ts",
    "./api/auth": "./src/api/auth.ts",
    "./api/resolve": "./src/api/resolve.ts",
    "./api/profile": "./src/api/profile.ts",
    "./api/link": "./src/api/link.ts",
    "./api/users": "./src/api/users.ts",
    "./api/federation": "./src/api/federation/index.ts",
    "./api/federation/inventory": "./src/api/federation/inventory.ts",
    "./api/federation/inventory.schema.json": "./src/api/federation/inventory.schema.json",
    "./api/federation/score": "./src/api/federation/score.ts",
    "./api/federation/score.schema.json": "./src/api/federation/score.schema.json",
    "./api/federation/codex": "./src/api/federation/codex.ts",
    "./api/federation/codex.schema.json": "./src/api/federation/codex.schema.json"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "zod": "^3.23.0 || ^4.0.0"
  },
  "devDependencies": {
    "zod": "^4.4.3"
  },
  "dependencies": {
    "@effect/schema": "^0.75",
    "effect": "^3.10.0"
  }
}
