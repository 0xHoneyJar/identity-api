{
  "name": "identity-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "identity-api — the central identity SoR for the freeside ecosystem. Hyper-based single-service building: wallet-first auth (SIWE + legacy EIP-191), resolution spine (users / wallets[] / credentials / per-world nyms), read-time compose over inventory + score + codex. Externally consumed as source-distributed vendored client (NOT npm).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xHoneyJar/identity-api.git"
  },
  "workspaces": [
    "packages/protocol",
    "packages/ports",
    "packages/adapters",
    "packages/mcp-tools",
    "packages/engine",
    "packages/ui"
  ],
  "scripts": {
    "dev": "bun --hot src/api/index.ts",
    "start": "bun src/api/index.ts",
    "build": "bun build src/api/index.ts --target=bun --outdir=dist",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "migrate": "bun scripts/migrate.ts up",
    "migrate:down": "bun scripts/migrate.ts down",
    "migrate:status": "bun scripts/migrate.ts status"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@usehyper/cli": "^0.1.1",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "zod": "^4.4.3"
  }
}
